<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/main.css">
    <%- renderStyles() %>
    <%- renderScripts() %>
</head>

<body class="<%= bodyClass %>">
    <header>
        <nav>
            <ul>
                <li><a href="/">Home</a></li>
                <li><a href="/about">About</a></li>
                <li><a href="/products">Products</a></li>
                <li><a href="/contact">Contact</a></li>
                <% if (isLoggedIn) { %>
                    <li>
                        <a href="/cart">Cart<% if (cartCount > 0) { %> (<%= cartCount %>)<% } %></a>
                    </li>
                    <li><a href="/dashboard">Dashboard</a></li>
                    <li><a href="/contact/mine">My Contacts</a></li>
                    <% if (user && (user.roleName === 'employee' || user.roleName === 'admin')) { %>
                        <li><a href="/register/list">All Users</a></li>
                        <li><a href="/contact/responses">Contact Responses</a></li>
                    <% } %>
                    <li>
                        <form action="/logout" method="POST" style="display: inline;">
                            <button type="submit" class="link-button">Logout</button>
                        </form>
                    </li>
                <% } %>
                <% if (!isLoggedIn) { %>
                    <li><a href="/login">Login</a></li>
                    <li><a href="/register">Register</a></li>
                <% } %>
            </ul>
        </nav>
    </header>

    <% const hasMessages = Object.values(messages).some(arr => arr.length > 0); %>
    <% if (hasMessages) { %>
        <div class="flash-messages">
            <% Object.keys(messages).forEach(type => { %>
                <% messages[type].forEach(message => { %>
                    <div class="flash <%= type %>"><%= message %></div>
                <% }); %>
            <% }); %>
        </div>
    <% } %>
