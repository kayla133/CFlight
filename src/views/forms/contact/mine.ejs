<%- include('../../partials/header') %>
<main>
    <h1><%= title %></h1>

    <% if (contactForms && contactForms.length > 0) { %>
        <div class="contact-responses">
            <% contactForms.forEach(form => { %>
                <div class="response-item status-<%= form.status %>">
                    <div class="response-item-header">
                        <h3 class="response-subject"><%= form.subject %></h3>
                        <span class="status-badge status-<%= form.status %>"><%= form.status %></span>
                    </div>
                    <p class="response-message"><%= form.message %></p>
                    <p class="response-date">Submitted: <%= new Date(form.created_at).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) %></p>

                    <% if (form.response) { %>
                        <div class="staff-response">
                            <strong>Response:</strong>
                            <p><%= form.response %></p>
                        </div>
                    <% } %>

                    <% if (form.status === 'received') { %>
                        <div class="contact-actions">
                            <a href="/contact/mine/<%= form.id %>/edit" class="btn btn-outline">Edit</a>
                            <form method="POST" action="/contact/mine/<%= form.id %>/delete" onsubmit="return confirm('Delete this message?');">
                                <button type="submit" class="btn btn-danger">Delete</button>
                            </form>
                        </div>
                    <% } %>
                </div>
            <% }); %>
        </div>
    <% } else { %>
        <p class="no-responses">You haven't submitted any contact messages yet.</p>
        <a href="/contact">Contact us</a>
    <% } %>
</main>
<%- include('../../partials/footer') %>
