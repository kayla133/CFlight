<%- include('../../partials/header') %>
<main>
    <form class="auth-form" method="POST" action="/contact/mine/<%= contact.id %>/edit">
        <h1><%= title %></h1>

        <div class="form-group">
            <label for="subject">Subject</label>
            <input type="text" id="subject" name="subject" value="<%= contact.subject %>" required>
        </div>

        <div class="form-group">
            <label for="message">Message</label>
            <textarea id="message" name="message" rows="6" required><%= contact.message %></textarea>
        </div>

        <button type="submit">Save Changes</button>

        <a href="/contact/mine">Cancel</a>
    </form>
</main>
<%- include('../../partials/footer') %>
