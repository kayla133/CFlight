<%- include('../partials/header', { title: locals.title }) %>
<main>
    <div class="course-header">
        <h1><%= faculty.name %></h1>
        <p class="course-meta"><%= faculty.title %> • <%= faculty.department %></p>
    </div>
    <div class="sections">
        <div class="sections-header">
            <h2>Contact & Office Information</h2>
        </div>
        <div class="section-list">
            <div class="section-card">
                <div class="section-room"><strong>Office Location:</strong> <%= faculty.office %></div>
            </div>
            <div class="section-card">
                <div class="section-time"><strong>Phone Number:</strong> <%= faculty.phone %></div>
            </div>
            <div class="section-card">
                <div class="section-professor">
                    <strong>Email Address:</strong>
                    <a href="mailto:<%= faculty.email %>"><%= faculty.email %></a>
                </div>
            </div>
        </div>
    </div>
    <div class="navigation">
        <p><a href="/faculty">&larr; Back to Faculty Directory</a></p>
    </div>
</main>
<%- include('../partials/footer') %>